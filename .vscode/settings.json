{
  // Format with oxfmt (via the Oxc extension, oxc.oxc-vscode) on save, for the
  // languages we own. myshows.js is skipped via .oxfmtrc ignorePatterns.
  // Oxfmt support is on by default now — no oxc.fmt.experimental flag needed.
  "editor.formatOnSave": true,
  "[javascript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[json]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[html]": { "editor.defaultFormatter": "oxc.oxc-vscode" }
}
