{
  // Format with oxfmt (via the Oxc VSCode extension) on save.
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.fmt.experimental": true,
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  // Run oxlint diagnostics in the editor.
  "oxc.lint.run": "onType",
  // The legacy hand-written artifact is not part of the modern src/ pipeline.
  "eslint.enable": false
}
