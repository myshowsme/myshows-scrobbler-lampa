{
  "name": "myshows-scrobbler-lampa",
  "version": "0.0.3",
  "description": "MyShows scrobbler plugin for Lampa",
  "keywords": [
    "lampa",
    "myshows",
    "scrobble"
  ],
  "homepage": "https://github.com/myshowsme/myshows-scrobbler-lampa#readme",
  "bugs": {
    "url": "https://github.com/myshowsme/myshows-scrobbler-lampa/issues"
  },
  "license": "MIT",
  "author": "MyShows",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myshowsme/myshows-scrobbler-lampa.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src index.html package.json",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
